# これをコピーして .env を作る:  cp .env.example .env
# docker compose が同じフォルダの .env を自動で読み込みます(.env はコミットされません)。

# 必須: Claude APIキー
ANTHROPIC_API_KEY=sk-ant-...

# 任意: 頭脳モデル(既定 haiku=激安。本番は claude-sonnet-5)
GACHA_MODEL=claude-haiku-4-5

# 決済の受取先。★テスト中は自分のウォレットアドレスにするとトークンが戻る(ガス代のみ)。
# フロント(Vercel)の NEXT_PUBLIC_GACHA_WALLET と必ず同じにすること。
GACHA_WALLET=0xあなたのウォレットアドレス

# ESP32 と共有する合言葉(★本番では必ず変更)
GACHA_UNLOCK_TOKEN=change-me-secret
